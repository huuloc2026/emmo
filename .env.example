# Application
NODE_ENV=development
PORT=3000
APP_NAME=NestJS Boilerplate 2026
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Database
DATABASE_URL=postgresql://nestjs:nestjs123@localhost:5432/nestjs_boilerplate?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nestjs
DB_PASSWORD=nestjs123
DB_DATABASE=nestjs_boilerplate
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0
REDIS_PREFIX=nestjs:

# JWT
JWT_SECRET=your-super-secret-jwt-key-with-at-least-32-characters-2026
JWT_REFRESH_SECRET=your-super-secret-refresh-key-with-at-least-32-characters-2026
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=nestjs-boilerplate
JWT_AUDIENCE=nestjs-boilerplate-client

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:3001

# PGAdmin (optional)
PGADMIN_EMAIL=admin@nestjs.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050